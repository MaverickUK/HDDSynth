	(text "Jumper - allow hardware\nreset to be disabled"
		(exclude_from_sim no)
		(at 197.866 100.33 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "79175303-c7a8-4412-ac2f-c0868d52d27a")
	)
	(text "===============================================\nRISING EDGE RESET CIRCUIT FOR PI PICO (RUN PIN)\n===============================================\nPURPOSE:\nGenerates a brief negative reset pulse on the Pico's RUN pin ONLY \nwhen external ISA 5V power is restored. This ensures a clean reboot \non power-cycling, even if the Pico is actively running on the \nbackup supercapacitor.\n\nOPERATION:\n1. POWER UP: The rising edge of ISA 5V passes through C9 to the gate \n   of Q1. Q1 turns ON hard, pulling the Pico's RUN pin to GND (Reset).\n2. NORMAL RUN: After ~10ms, C9 charges fully via R10. The gate voltage \n   drops to 0V, turning Q1 OFF and releasing the RUN pin to go HIGH.\n3. POWER DOWN: When ISA 5V drops, D5 instantly discharges C9 to GND, \n   safely clamping negative voltage spikes and priming the circuit.\n4. BACKUP POWER: The Pico continues running from the supercap while \n   Q1 remains safely OFF."
		(exclude_from_sim no)
		(at 54.356 94.234 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "9430dfa3-b6d5-4ad2-a4d1-27a880586a7d")
	)
	(text "Pin 1 : Gate (G)\nPin 2 : Source (S)\nPin 3 : Drain (D)"
		(exclude_from_sim no)
		(at 183.642 114.3 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "cfe09133-488f-4546-917e-9d187535eef0")
	)
